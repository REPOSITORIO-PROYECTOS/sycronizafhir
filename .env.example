LOCAL_POSTGRES_URL=postgres://postgres:your-local-password@127.0.0.1:5433/mascotas?sslmode=disable
DB_SOURCE_MODE=manual
DB_SOURCE_PRIORITY=docker,local
SQLITE_QUEUE_PATH=./sync_queue.db

HOST_SUPABASE=db.your-project.supabase.co
PUERTO_SUPABASE=5432
USUARIO_SUPABASE=postgres
CONTRASENA_SUPABASE=your-db-password
SUPABASE_DB_NAME=postgres
SUPABASE_DB_SSLMODE=require

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_REALTIME_URL=wss://your-project.supabase.co/realtime/v1/websocket?vsn=1.0.0
SUPABASE_REALTIME_CHANNEL=realtime:public:pedidos
SUPABASE_REALTIME_SCHEMA=public
SUPABASE_REALTIME_TABLE=pedidos

OUTBOUND_INTERVAL_SECONDS=60
DEVICE_ID=
DEVICE_PRESENCE_INTERVAL_SECONDS=60
SYNC_SOURCE_SCHEMA=public
SYNC_EXCLUDE_TABLES=sync_buzon_pedidos
